# Salin file ini menjadi .env dan isi nilainya

# URL WebSocket ke backend (production: Railway/Render/Fly.io)
# Contoh: wss://colour-war-server.up.railway.app/ws
VITE_WS_URL=ws://localhost:3001/ws

# URL API REST ke backend
# Contoh: https://colour-war-server.up.railway.app
VITE_API_URL=http://localhost:3001
